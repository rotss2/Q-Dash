# Supabase Configuration
# Create a project at https://supabase.com and copy your credentials here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin login configuration
# These values are used by the server to authenticate admin access.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Q-Dash111_2005
ADMIN_USER_ID=c6ae1256-0bda-4a98-8fcc-8765446f9d32
SESSION_SECRET=replace-with-a-strong-secret

# Supabase service key for server-side admin queries
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Configuration (FREE OPTION FOR STUDENTS)
# ==========================================
# 
# STEP 1: Get FREE API key from Google:
# https://aistudio.google.com/app/apikey
#
# STEP 2: Create new API key (DO NOT share this key with anyone!)
#
# STEP 3: Copy the key (starts with "AIza...") and paste below:

GOOGLE_GEMINI_API_KEY=AIza-paste-your-new-key-here

# STEP 4: For production (Render.com), add this same key to Environment Variables
# Dashboard > Your Service > Environment > Add GOOGLE_GEMINI_API_KEY
#
# FREE TIER LIMITS:
# - 1,500 requests per day
# - 60 requests per minute
# - Perfect for thesis/research work!

# (Optional) OpenAI - Only if you want higher quality and have budget
# OPENAI_API_KEY=sk-your-openai-key-here
